# Copy to .env and fill in（pydantic-settings：同名键时环境变量优先于 .env）。

# GLM-5（智谱AI Claude兼容接口）
# 若终端曾 export 过 ANTHROPIC_AUTH_TOKEN，会覆盖 .env；可先 unset ANTHROPIC_AUTH_TOKEN
ANTHROPIC_AUTH_TOKEN=
# ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic
# ANTHROPIC_MODEL=glm-5
# ANTHROPIC_CHAT_PATH=chat/completions
# ANTHROPIC_STREAM=false
# ANTHROPIC_TEMPERATURE=0.2
# ANTHROPIC_MAX_TOKENS=4096

# Simulation（默认：沪深 A + Yahoo 代码：上证 .SS / 深证 .SZ）
INITIAL_CAPITAL=100000
# fixed = 仅在 UNIVERSE 内交易；free = 模型可主动选任意沪深A股（引擎按需拉行情），UNIVERSE 仅作参考/种子
SELECTION_MODE=fixed
# free 模式下用于交易日历的指数/基准（Yahoo 代码）
CALENDAR_SYMBOL=000001.SS
# 参考基数（沪深300 / 中证500 / 科创50）：默认 300 用指数，500 与科创50 用主流 ETF（Yahoo 上对应指数常缺数据）；逗号分隔可改
REFERENCE_BENCHMARKS=000300.SS,510500.SS,588000.SS
UNIVERSE=600519.SS,601318.SS,300750.SZ
START_DATE=2024-01-01
END_DATE=2024-12-31
# llm      = LLM（GLM-5）调仓
# buy_hold = 首日近似等权买入并持有（无需 API，用于验通路）
# momentum = 双均线+截面动量+大盘择时（无需 API；周度调仓，A股经典轮动）
# mainline = 游资派"连板龙头+主线追踪"短线策略（akshare 涨停池+龙虎榜，日度调仓）
#            2026-05 那 21 天 +61.5%，但 2025 全年 -68%（仅适合主升浪行情）
# rotation = 31 行业 ETF 周度轮动【推荐】，2025 +34.29% / 最大回撤 -13%
#            超额沪深300 +12.54pp，依赖本地 etf_daily.csv（Tushare）
STRATEGY_MODE=llm

# ===== rotation 策略参数（STRATEGY_MODE=rotation 时生效）=====
# 候选池硬编码 31 个行业 ETF（见 strategies/rotation.py:ETF_UNIVERSE）
# ROTATION_TOP_K=3                      # 持仓 ETF 数（等权）
# ROTATION_MOMENTUM_WINDOW=20           # 动量评分窗口
# ROTATION_REBALANCE_EVERY_DAYS=5       # 调仓周期（5=周度）
# ROTATION_STOP_LOSS_PCT=8              # 单只 ETF 止损
# ROTATION_REGIME_SYMBOL=000300.SS      # 大盘择时基准
# ROTATION_REGIME_MA_WINDOW=60          # HS300 跌破 MA60 全空仓
# ROTATION_REGIME_ENABLED=true
# ROTATION_REQUIRE_UPTREND=true         # 候选 ETF 必须站稳 MA20
# ROTATION_UPTREND_MA_WINDOW=20
# ROTATION_DEPLOY_FRACTION=0.95
# ROTATION_LIVE_ENABLED=true            # 启用 14:45 自动调仓（不依赖 STRATEGY_MODE）
#                                         若 STRATEGY_MODE=rotation 自动开启

# ===== mainline 策略参数（STRATEGY_MODE=mainline 时生效）=====
# 数据源：akshare 历史涨停池 + 龙虎榜（按日缓存到 data/mainline_cache/）
# MAINLINE_TOP_K=2                       # 持仓只数（越集中弹性越大）
# MAINLINE_MIN_CONSEQ_LIMITS=2           # 至少 N 板才入选（1=首板，2=2板起步）
# MAINLINE_MAX_PRIOR5D_RET_PCT=60        # 近 5 日已涨超 X% 不追（持仓股豁免）
# MAINLINE_MIN_MARKET_CAP_YI=20          # 流通市值下限（亿）
# MAINLINE_MAX_MARKET_CAP_YI=1500        # 流通市值上限（亿，持仓股豁免）
# MAINLINE_STOP_LOSS_PCT=12              # 当日跌幅止损
# MAINLINE_TRAIL_MA_DAYS=5               # 跌破此均线卖出
# MAINLINE_TAKE_PROFIT_PCT=120           # 盈利 X% 且收阴时止盈（设大让赢家跑）
# MAINLINE_REBALANCE_EVERY_DAYS=1        # 调仓周期
# MAINLINE_CANDIDATE_POOL_SIZE=10        # 候选池大小（越大越能容纳龙头）
# MAINLINE_MAX_OPEN_GAP_PCT=15           # 高开过滤（>15% 跳空不追，5板后涨停板要 ≥9%）
# MAINLINE_DEPLOY_FRACTION=0.95
# 配合 MAX_POSITION_FRACTION=0.55 让单只票最多占 55%

# ===== momentum 策略参数（仅 STRATEGY_MODE=momentum 时生效）=====
# 选股池 = UNIVERSE + MARKET_SCAN_UNIVERSE 去重后的全集
# MOMENTUM_TOP_K=5                  # 持仓只数（等权配置）
# MOMENTUM_RET20_MIN=5.0            # 近 20 日动量阈值 (%)
# MOMENTUM_STOP_LOSS_PCT=8.0        # 个股止损（浮亏 % 触发）
# MOMENTUM_REBALANCE_EVERY_DAYS=5   # 调仓周期（交易日）
# MOMENTUM_REGIME_SYMBOL=000300.SS  # 大盘择时基准
# MOMENTUM_REGIME_MA_WINDOW=200     # 大盘 MA 窗口（基准低于此 MA → 空仓）
# MOMENTUM_MA_SHORT=20              # 多头排列短均线
# MOMENTUM_MA_LONG=60               # 多头排列长均线
# MOMENTUM_WINDOW=60                # 排序用动量窗口
# MOMENTUM_DEPLOY_FRACTION=0.95     # 资金部署比例
# 日度调仓
REBALANCE_EVERY_DAYS=1
MAX_POSITION_FRACTION=0.30
# A 股常见一手 100 股；美股可改为 1
LOT_SIZE=100
# 佣金近似（双边合并为单次费率示意，可改）
COMMISSION_RATE=0.00025

# 可选：扩展上下文（舆情/情绪/研报摘要等）。指向你自己的 HTTP 服务；POST JSON 见 invest_system/market_context.py
# MARKET_CONTEXT_URL=
# MARKET_CONTEXT_TIMEOUT_SEC=8
# MARKET_CONTEXT_MAX_CHARS=8000

# free 模式增强：给模型一组“可交易候选池 TopN”
# 不填 MARKET_SCAN_UNIVERSE 时会自动使用全市场实时榜单扫描（依赖 akshare）；
# 若你只想在自定义池里扫描，再填写 MARKET_SCAN_UNIVERSE。
# MARKET_SCAN_UNIVERSE=600519.SS,601318.SS,300750.SZ,002594.SZ,000858.SZ
# MARKET_CANDIDATES_TOP_N=20
# strict=true 时，free 模式只允许候选池内买入（卖出现有持仓不受限）
# FREE_SELECTION_ENFORCE_CANDIDATES=true
# 自动扫描容错：连接失败时重试；仍失败则回退到最近一次成功缓存（默认 240 分钟内）
# MARKET_SCAN_RETRIES=3
# MARKET_SCAN_CACHE_MAX_AGE_MIN=240
# 网络/代理（扫描源用；不填则直连）。示例：
# MARKET_SCAN_HTTP_PROXY=http://127.0.0.1:7890
# MARKET_SCAN_HTTPS_PROXY=http://127.0.0.1:7890
# MARKET_SCAN_NO_PROXY=localhost,127.0.0.1
# 可选连通性探测 URL（用于更明确定位网络问题）：
# MARKET_SCAN_PROBE_URL=https://push2.eastmoney.com
# MARKET_SCAN_PROBE_TIMEOUT_SEC=3
# 盘中最新价快照（仅供模型参考，不作为回测撮合成交价）
# INTRADAY_QUOTE_ENABLED=true
# INTRADAY_QUOTE_PERIOD=1d
# INTRADAY_QUOTE_INTERVAL=1m

# 看盘助手（盘前/开盘5分钟/午间/收盘）：须在 STRATEGY_MODE=llm 时才会生成；博文在 ASSISTANT_ARTIFACTS_DIR/<日期>/
# INTRADAY_ASSISTANT=true
# ASSISTANT_ARTIFACTS_DIR=./data/articles
# 逗号分隔 **RSS/Atom 订阅 XML 地址**（勿填网站首页）；最多处理 ASSISTANT_MAX_RSS_FEEDS 个
# ASSISTANT_RSS_URLS=
# ASSISTANT_MAX_RSS_FEEDS=12
# 可选：POST JSON 聚合资讯（见 assistant/gather.py）
# ASSISTANT_GATHER_URL=
# ASSISTANT_MODEL=
# ASSISTANT_TEMPERATURE=0.55
# ASSISTANT_HTTP_TIMEOUT_SEC=15
# ASSISTANT_MAX_RSS_ITEMS_TOTAL=24
# 主动检索 + 结构化摘要
# ASSISTANT_NEWS_SEARCH_ENABLED=true
# ASSISTANT_NEWS_SEARCH_QUERIES=A股,沪深,算力,半导体,存储芯片,北向资金,政策
# ASSISTANT_MAX_SEARCH_QUERIES=8
# ASSISTANT_MAX_ITEMS_PER_TOPIC=4
# ASSISTANT_MAX_BUNDLE_CHARS=12000
# ASSISTANT_LLM_TIMEOUT_SEC=120

# Storage
DATA_DIR=./data

# 盘中定时任务（launchd + invest-live-phase）持久化路径与前缀
# LIVE_PORTFOLIO_STATE_PATH=./data/live_portfolio_state.json
# LIVE_EQUITY_CSV_PREFIX=live_intraday

# 行情缓存清理（每次跑完模拟自动收尾，避免 ohlcv_*.pkl / prices_*.pkl 越积越多）
# CACHE_PRUNE_ENABLED=true
# CACHE_PRUNE_MAX_AGE_DAYS=14

# ===== Railway / 部署相关 =====
# Volume 挂载到 /data 时，把所有数据路径都指向 /data：
# DATA_DIR=/data
# ASSISTANT_ARTIFACTS_DIR=/data/articles
# LIVE_PORTFOLIO_STATE_PATH=/data/live_portfolio_state.json

# 首次启动时若 DATA_DIR 为空，从镜像内置的 ./seed_data/ 播种（避免冷启动空数据）
# SEED_DATA_ENABLED=true
# SEED_DATA_DIR=./seed_data

# 看板登录（公网必开）。多账号用逗号分隔：u1:p1,u2:p2
# DASHBOARD_AUTH_ENABLED=true
# DASHBOARD_USERS=admin:change-me-please

# A 股 T+1：当日买入当日不可卖。回测/纸面测试想放开置 false
# T_PLUS_1_ENABLED=true

# ===== 实盘交易配置 =====
# broker_mode: paper（模拟盘）或 jvquant（实盘）
# BROKER_MODE=paper

# jvQuant 实盘（需注册 jvQuant 并开通东方财富账户）
# 个人账户仅支持东方财富，机构账户无券商限制
# JVQUANT_TOKEN=
# JVQUANT_ACCOUNT=
# JVQUANT_PASSWORD=
