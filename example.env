# Copy to .env and fill in（pydantic-settings：同名键时环境变量优先于 .env）。

# DeepSeek（与控制台 curl 一致时：BASE + /chat/completions，无 v1）
# 若终端曾 export 过 DEEPSEEK_API_KEY，会覆盖 .env；可先 unset DEEPSEEK_API_KEY
DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat
# 仅当你用 OpenAI 兼容 /v1 时改为：DEEPSEEK_CHAT_PATH=v1/chat/completions
# DEEPSEEK_CHAT_PATH=chat/completions
# DEEPSEEK_STREAM=false
# deepseek-v4-pro 等可参考控制台示例：
# DEEPSEEK_MODEL=deepseek-v4-pro
# DEEPSEEK_THINKING_TYPE=enabled
# DEEPSEEK_REASONING_EFFORT=high
# 或与文档一致的任意额外字段（合法 JSON 对象，会合并进请求体）：
# DEEPSEEK_EXTRA_JSON={"thinking":{"type":"enabled"},"reasoning_effort":"high"}

# Simulation（默认：沪深 A + Yahoo 代码：上证 .SS / 深证 .SZ）
INITIAL_CAPITAL=100000
# fixed = 仅在 UNIVERSE 内交易；free = 模型可主动选任意沪深A股（引擎按需拉行情），UNIVERSE 仅作参考/种子
SELECTION_MODE=fixed
# free 模式下用于交易日历的指数/基准（Yahoo 代码）
CALENDAR_SYMBOL=000001.SS
# 参考基数（沪深300 / 中证500 / 科创50）：默认 300 用指数，500 与科创50 用主流 ETF（Yahoo 上对应指数常缺数据）；逗号分隔可改
REFERENCE_BENCHMARKS=000300.SS,510500.SS,588000.SS
UNIVERSE=600519.SS,601318.SS,300750.SZ
START_DATE=2024-01-01
END_DATE=2024-12-31
# llm = DeepSeek 调仓; buy_hold = 首日近似等权买入并持有（无需 API，用于验通路）
STRATEGY_MODE=llm
# 日度调仓
REBALANCE_EVERY_DAYS=1
MAX_POSITION_FRACTION=0.30
# A 股常见一手 100 股；美股可改为 1
LOT_SIZE=100
# 佣金近似（双边合并为单次费率示意，可改）
COMMISSION_RATE=0.00025

# 可选：扩展上下文（舆情/情绪/研报摘要等）。指向你自己的 HTTP 服务；POST JSON 见 invest_system/market_context.py
# MARKET_CONTEXT_URL=
# MARKET_CONTEXT_TIMEOUT_SEC=8
# MARKET_CONTEXT_MAX_CHARS=8000

# free 模式增强：给模型一组“可交易候选池 TopN”
# 不填 MARKET_SCAN_UNIVERSE 时会自动使用全市场实时榜单扫描（依赖 akshare）；
# 若你只想在自定义池里扫描，再填写 MARKET_SCAN_UNIVERSE。
# MARKET_SCAN_UNIVERSE=600519.SS,601318.SS,300750.SZ,002594.SZ,000858.SZ
# MARKET_CANDIDATES_TOP_N=20
# strict=true 时，free 模式只允许候选池内买入（卖出现有持仓不受限）
# FREE_SELECTION_ENFORCE_CANDIDATES=true
# 自动扫描容错：连接失败时重试；仍失败则回退到最近一次成功缓存（默认 240 分钟内）
# MARKET_SCAN_RETRIES=3
# MARKET_SCAN_CACHE_MAX_AGE_MIN=240
# 网络/代理（扫描源用；不填则直连）。示例：
# MARKET_SCAN_HTTP_PROXY=http://127.0.0.1:7890
# MARKET_SCAN_HTTPS_PROXY=http://127.0.0.1:7890
# MARKET_SCAN_NO_PROXY=localhost,127.0.0.1
# 可选连通性探测 URL（用于更明确定位网络问题）：
# MARKET_SCAN_PROBE_URL=https://push2.eastmoney.com
# MARKET_SCAN_PROBE_TIMEOUT_SEC=3
# 盘中最新价快照（仅供模型参考，不作为回测撮合成交价）
# INTRADAY_QUOTE_ENABLED=true
# INTRADAY_QUOTE_PERIOD=1d
# INTRADAY_QUOTE_INTERVAL=1m

# 看盘助手（盘前/开盘5分钟/午间/收盘）：须在 STRATEGY_MODE=llm 时才会生成；博文在 ASSISTANT_ARTIFACTS_DIR/<日期>/
# INTRADAY_ASSISTANT=false
# ASSISTANT_ARTIFACTS_DIR=./artifacts/assistant
# 逗号分隔 **RSS/Atom 订阅 XML 地址**（勿填网站首页）；最多处理 ASSISTANT_MAX_RSS_FEEDS 个
# ASSISTANT_RSS_URLS=
# ASSISTANT_MAX_RSS_FEEDS=12
# 可选：POST JSON 聚合资讯（见 assistant/gather.py）
# ASSISTANT_GATHER_URL=
# ASSISTANT_MODEL=
# ASSISTANT_TEMPERATURE=0.55
# ASSISTANT_HTTP_TIMEOUT_SEC=15
# ASSISTANT_MAX_RSS_ITEMS_TOTAL=24
# 主动检索 + 结构化摘要
# ASSISTANT_NEWS_SEARCH_ENABLED=true
# ASSISTANT_NEWS_SEARCH_QUERIES=A股,沪深,算力,半导体,存储芯片,北向资金,政策
# ASSISTANT_MAX_SEARCH_QUERIES=8
# ASSISTANT_MAX_ITEMS_PER_TOPIC=4
# ASSISTANT_MAX_BUNDLE_CHARS=12000
# ASSISTANT_LLM_TIMEOUT_SEC=120

# Storage
DATA_DIR=./data

# 盘中定时任务（launchd + invest-live-phase）持久化路径与前缀
# LIVE_PORTFOLIO_STATE_PATH=./data/live_portfolio_state.json
# LIVE_EQUITY_CSV_PREFIX=live_intraday
